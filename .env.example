# NestJS API
PORT=3000

# Optional:
# - Leave empty for local SQL.js mode
# - Set to Neon/Postgres URL in staging/production
# Example: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/padel?sslmode=require
DATABASE_URL=

# Optional override: force sqljs local mode even if DATABASE_URL exists
# DB_DRIVER=sqljs

# Local sqljs persistence (keeps accounts after restart)
DB_LOCAL_PERSIST=true
DB_LOCAL_PATH=data/padel-local.sqlite

# Set true on Render/Neon
DB_SSL=true

# For production keep false and run proper migrations
DB_SYNC=true
